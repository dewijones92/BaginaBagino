{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing for the rules engine. Scope is narrow (engine only) to keep runs under ~2 min. See CLAUDE.md 'Mutation testing'.",
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/engine/reducer.ts",
    "src/engine/scoring.ts",
    "src/engine/actions.ts",
    "src/engine/homework.ts",
    "src/engine/deck.ts",
    "src/engine/board.ts"
  ],
  "ignorePatterns": ["dist", "coverage", "reports"],
  "checkers": [],
  "concurrency": 4,
  "timeoutMS": 15000,
  "thresholds": {
    "high": 85,
    "low": 70,
    "break": null
  },
  "reporters": ["progress", "html", "clear-text"],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "tempDirName": ".stryker-tmp"
}
