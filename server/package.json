{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "description": "Bagino Bagina real-time server (rules engine + Socket.IO transport)",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit -p tsconfig.json",
    "playtest": "tsx tests/e2e/playtest.ts"
  },
  "dependencies": {
    "@bagina/schema": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "better-sqlite3": "^11.7.0",
    "fastify": "^5.2.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.9",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
